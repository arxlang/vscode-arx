{
  "name": "vscode-arx",
  "displayName": "ArxLang",
  "description": "Highlight-only VS Code extension for the Arx programming language.",
  "version": "0.2.0",
  "publisher": "arxlang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arxlang/vscode-arx.git"
  },
  "homepage": "https://github.com/arxlang/vscode-arx#readme",
  "bugs": {
    "url": "https://github.com/arxlang/vscode-arx/issues"
  },
  "icon": "images/icon.png",
  "files": [
    "language-configuration.json",
    "syntaxes/**",
    "syntax/arx.syntax.json",
    "images/icon.png",
    "README.md",
    "LICENSE"
  ],
  "categories": [
    "Programming Languages"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "arx",
        "aliases": [
          "ArxLang",
          "Arx",
          "arx"
        ],
        "extensions": [
          ".x",
          ".arx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "arx",
        "scopeName": "source.arx",
        "path": "./syntaxes/arx.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "sync:syntax": "bash ./scripts/sync-syntax.sh",
    "build:grammar": "node ./scripts/build-grammar.mjs --write",
    "check:grammar": "node ./scripts/build-grammar.mjs --check",
    "build:vsix": "bash ./scripts/build.sh --no-dependencies",
    "publish:all": "bash ./scripts/publish.sh --all --no-dependencies"
  }
}
