{
  "syntax_pack_version": "0.1.0",
  "language": "arx",
  "status": "draft",
  "source_of_truth": "This manifest is the normative lexical source for editor tooling.",
  "file_extensions": [
    ".x",
    ".arx"
  ],
  "keywords": {
    "reserved": [
      "const",
      "else",
      "extern",
      "fn",
      "for",
      "if",
      "in",
      "return",
      "then",
      "var"
    ],
    "contextual": []
  },
  "literals": [],
  "comment": {
    "line": {
      "delimiters": [
        "#"
      ]
    },
    "block": {
      "enabled": false,
      "open": "",
      "close": "",
      "nesting": false
    },
    "notes": [
      "Only # line comments are currently specified.",
      "TODO(ARX-LEX-COMMENT-002): confirm whether // will be introduced as a comment delimiter."
    ]
  },
  "strings": {
    "supported": false,
    "quote_types": [],
    "triple_quotes": false,
    "raw_prefixes": [],
    "escapes": [],
    "interpolation": {
      "enabled": false,
      "start": "",
      "end": ""
    },
    "notes": [
      "TODO(ARX-LEX-STRINGS-001): define string literals and escapes."
    ]
  },
  "numbers": {
    "formats": [
      "decimal_integer",
      "decimal_float"
    ],
    "bases": [
      10
    ],
    "underscores": {
      "allowed": false
    },
    "suffixes": [],
    "exponent": {
      "allowed": false,
      "forms": []
    },
    "leading_dot_float": true,
    "trailing_dot_float": true,
    "multiple_dots": "invalid"
  },
  "identifiers": {
    "start": "Unicode letter or underscore",
    "continue": "Unicode alphanumeric or underscore",
    "pattern": "(?:[_\\p{L}])(?:[_\\p{L}\\p{N}])*",
    "unicode_policy": "Current behavior follows Unicode categories from host runtime. TODO(ARX-LEX-IDENT-001): formalize policy (e.g., XID_Start/XID_Continue vs ASCII-only)."
  },
  "whitespace": {
    "indentation_significant": true,
    "indent_unit": "2 spaces",
    "tabs": "unspecified",
    "newlines_significant": true,
    "blank_lines": "ignored for indentation transitions"
  },
  "operators": {
    "symbols": [
      "=",
      "<",
      ">",
      "+",
      "-",
      "*",
      "/",
      ":",
      ",",
      ";"
    ],
    "assignment": [
      "="
    ],
    "comparison": [
      "<",
      ">"
    ],
    "arithmetic": [
      "+",
      "-",
      "*",
      "/"
    ],
    "punctuation": [
      ":",
      ",",
      ";"
    ],
    "notes": [
      "TODO(ARX-LEX-OPS-001): finalize multi-character operators (==, !=, <=, >=, ->)."
    ]
  },
  "brackets": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "{",
      "}"
    ]
  ]
}
