{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Arx",
  "scopeName": "source.arx",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.arx",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.arx",
          "match": "\"(?:\\\\.|[^\"\\\\\\n])*\""
        },
        {
          "name": "string.quoted.single.arx",
          "match": "'(?:\\\\.|[^'\\\\\\n])*'"
        },
        {
          "name": "invalid.illegal.unterminated-string.arx",
          "match": "\"(?:\\\\.|[^\"\\\\\\n])*$"
        },
        {
          "name": "invalid.illegal.unterminated-string.arx",
          "match": "'(?:\\\\.|[^'\\\\\\n])*$"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.definition.arx",
          "match": "\\b(fn)\\s+((?:[_\\p{L}])(?:[_\\p{L}\\p{N}])*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.arx"
            },
            "2": {
              "name": "entity.name.function.arx"
            }
          }
        },
        {
          "name": "meta.variable.declaration.arx",
          "match": "\\b(?:const|var)\\s+((?:[_\\p{L}])(?:[_\\p{L}\\p{N}])*)\\b",
          "captures": {
            "1": {
              "name": "variable.other.definition.arx"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.arx",
          "match": "\\b(?:const|else|extern|fn|for|if|in|return|then|var)\\b"
        },
        {
          "name": "keyword.other.contextual.arx",
          "match": "(?!)"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.arx",
          "match": "\\b(?:true|false|null)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.decimal.arx",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.float.decimal.arx",
          "match": "(?<![\\w.])\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.float.decimal.arx",
          "match": "\\b\\d+\\.(?!\\.)"
        },
        {
          "name": "constant.numeric.integer.decimal.arx",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arx",
          "match": "(?:==|!=|<=|>=|->)"
        },
        {
          "name": "keyword.operator.arx",
          "match": "[=<>+\\-*/]"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.arx",
          "match": "\\b(?!(?:const|else|extern|fn|for|if|in|return|then|var)\\b)((?:[_\\p{L}])(?:[_\\p{L}\\p{N}])*)(?=\\s*\\()"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.arx",
          "match": "[:,;]"
        },
        {
          "name": "punctuation.section.brackets.begin.arx",
          "match": "[({[]"
        },
        {
          "name": "punctuation.section.brackets.end.arx",
          "match": "[)}\\]]"
        }
      ]
    }
  }
}
